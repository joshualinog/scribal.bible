        </div>
      {% endif %}

    </div>

    <div class="mt-10 flex justify-center">
      <a href="/#post-grid" class="text-sm font-semibold text-brick-red-600 hover:text-brick-red-500 dark:text-brick-red-400 dark:hover:text-brick-red-300">
        View all posts <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</div>