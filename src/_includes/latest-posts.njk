<div class="bg-cream-50 py-24 sm:py-32 dark:bg-dark-black-900">
  <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
    <h2 class="text-base/7 font-semibold text-brick-red-600 dark:text-brick-red-400">Recently Published</h2>
    <p class="mt-2 max-w-lg text-4xl font-semibold tracking-tight text-pretty text-dark-black-900 sm:text-5xl dark:text-cream-50">Fresh explorations</p>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">

      {# Post 0 — top left, col-span-3 #}
      {% set post = posts[0] %}
      {% if post %}
        {% set _imgs = defaultImages[post.template] if (post.template and defaultImages[post.template]) else defaultImages["default"] %}
        {% set _heroImg = post.mainImage if post.mainImage else _imgs[post.id % _imgs.length] %}
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 rounded-lg bg-cream-100 max-lg:rounded-t-4xl lg:rounded-tl-4xl dark:bg-charcoal-800"></div>
          <a href="/posts/{{ post.slug }}/" class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-t-[calc(2rem+1px)] lg:rounded-tl-[calc(2rem+1px)] group">
            <img src="{{ _heroImg }}" alt="{{ post.title }}" class="h-80 object-cover object-center w-full" onerror="this.src=''" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-brick-red-600 dark:text-brick-red-400">
                {% if post.category %}{{ post.category }}{% elif post.labels and post.labels.length %}{% for label in post.labels %}{% if label != "isPost" and loop.first %}{{ label }}{% endif %}{% endfor %}{% else %}Post{% endif %}
              </h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-dark-black-900 group-hover:text-brick-red-700 dark:text-cream-100 dark:group-hover:text-brick-red-300 line-clamp-2">{{ post.title }}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-charcoal-600 dark:text-cream-400 line-clamp-3">{{ post.description or post.excerpt }}</p>
            </div>
          </a>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 max-lg:rounded-t-4xl lg:rounded-tl-4xl dark:outline-white/15"></div>
        </div>
      {% endif %}

