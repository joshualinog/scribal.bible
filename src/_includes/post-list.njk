<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl dark:text-white">From the blog</h2>
      <p class="mt-2 text-lg/8 text-gray-600 dark:text-gray-300">Scribal studies, reflections, and explorations.</p>
    </div>
    <div id="post-grid" class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {% for post in pagination.items %}
      <article class="flex flex-col items-start justify-between">

        {# Card image — real mainImage or indigo gradient fallback #}
        <div class="relative w-full">
          {% if post.mainImage %}
            <img src="{{ post.mainImage }}" alt="{{ post.title }}" class="aspect-video w-full rounded-2xl bg-gray-100 object-cover sm:aspect-2/1 lg:aspect-3/2 dark:bg-gray-800" />
          {% else %}
            <div class="aspect-video w-full rounded-2xl sm:aspect-2/1 lg:aspect-3/2 bg-linear-to-br from-indigo-50 to-indigo-100 dark:from-indigo-950 dark:to-gray-900 flex items-center justify-center">
              <svg class="size-10 text-indigo-300 dark:text-indigo-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          {% endif %}
          <div class="absolute inset-0 rounded-2xl inset-ring inset-ring-gray-900/10 dark:inset-ring-white/10"></div>
        </div>

        <div class="flex max-w-xl grow flex-col justify-between">
          <div class="mt-8 flex items-center gap-x-4 text-xs">
            <time datetime="{{ post.date or post.createdAt }}" class="text-gray-500 dark:text-gray-400">
              {{ (post.date or post.createdAt) | date("MMM dd, yyyy") }}
            </time>
            {% if post.category %}
              <span class="relative z-10 rounded-full bg-indigo-50 px-3 py-1.5 font-medium text-indigo-600 dark:bg-indigo-500/10 dark:text-indigo-400">
                {{ post.category }}
              </span>
            {% elif post.labels and post.labels.length %}
              {% for label in post.labels %}
                {% if label != "isPost" and loop.first %}
                  <span class="relative z-10 rounded-full bg-gray-100 px-3 py-1.5 font-medium text-gray-600 dark:bg-white/10 dark:text-gray-400">{{ label }}</span>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>

          <div class="group relative grow">
            <h3 class="mt-3 text-lg/6 font-semibold text-gray-900 group-hover:text-gray-600 dark:text-white dark:group-hover:text-gray-300">
              <a href="/posts/{{ post.slug }}">
                <span class="absolute inset-0"></span>
                {{ post.title }}
              </a>
            </h3>
            <p class="mt-5 line-clamp-3 text-sm/6 text-gray-600 dark:text-gray-400">
              {{ post.description or post.excerpt }}
            </p>
          </div>

          {# Author row — initials avatar #}
          {% if post.author %}
            <div class="relative mt-8 flex items-center gap-x-3">
              <div class="size-10 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-semibold text-indigo-700 dark:text-indigo-300 uppercase">
                  {{ post.author[0] }}
                </span>
              </div>
              <div class="text-sm/6">
                <p class="font-semibold text-gray-900 dark:text-white">{{ post.author }}</p>
              </div>
            </div>
          {% endif %}

        </div>
      </article>
      {% endfor %}
    </div>
    <div id="pagination-nav">
    <nav class="flex items-center justify-between border-t border-gray-200 px-4 sm:px-0 dark:border-white/10 mt-16">
      <div class="-mt-px flex w-0 flex-1">
        {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" class="inline-flex items-center border-t-2 border-transparent pt-4 pr-1 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-white/20 dark:hover:text-gray-200">
          <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="mr-3 size-5 text-gray-400 dark:text-gray-500">
            <path d="M18 10a.75.75 0 0 1-.75.75H4.66l2.1 1.95a.75.75 0 1 1-1.02 1.1l-3.5-3.25a.75.75 0 0 1 0-1.1l3.5-3.25a.75.75 0 1 1 1.02 1.1l-2.1 1.95h12.59A.75.75 0 0 1 18 10Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
          Previous
        </a>
        {% else %}
        <span class="inline-flex items-center border-t-2 border-transparent pt-4 pr-1 text-sm font-medium text-gray-300 dark:text-gray-600">Previous</span>
        {% endif %}
      </div>
      <div class="-mt-px flex">
        {% set current = pagination.pageNumber + 1 %}
        {% set total = ((posts | length) / 12) | round(0, 'ceil') %}
        {% if total > 1 %}
        <a href="/" class="inline-flex items-center border-t-2 {% if current == 1 %}border-indigo-500 text-indigo-600 dark:border-indigo-400 dark:text-indigo-400{% else %}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-white/20 dark:hover:text-gray-200{% endif %} px-4 pt-4 text-sm font-medium">1</a>
        {% if current > 3 %}
        <span class="inline-flex items-center border-t-2 border-transparent px-4 pt-4 text-sm font-medium text-gray-500">...</span>
        {% endif %}
        {% set start = 2 if current-1 < 2 else current-1 %}
        {% set end = total if current+2 > total else current+2 %}
        {% for i in range(start, end + 1) %}
        {% set page_num = i - 1 %}
        {% set page_url = "/" + page_num | string + "/" if page_num > 0 else "/" %}
        <a href="{{ page_url }}" class="inline-flex items-center border-t-2 {% if i == current %}border-indigo-500 text-indigo-600 dark:border-indigo-400 dark:text-indigo-400{% else %}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-white/20 dark:hover:text-gray-200{% endif %} px-4 pt-4 text-sm font-medium">{{ i }}</a>
        {% endfor %}
        {% if current < total - 2 %}
        <span class="inline-flex items-center border-t-2 border-transparent px-4 pt-4 text-sm font-medium text-gray-500">...</span>
        {% endif %}
        {% if total > 1 %}
        {% set last_page_num = total - 1 %}
        {% set last_url = "/" + last_page_num | string + "/" %}
        <a href="{{ last_url }}" class="inline-flex items-center border-t-2 {% if current == total %}border-indigo-500 text-indigo-600 dark:border-indigo-400 dark:text-indigo-400{% else %}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-white/20 dark:hover:text-gray-200{% endif %} px-4 pt-4 text-sm font-medium">{{ total }}</a>
        {% endif %}
        {% endif %}
      </div>
      <div class="-mt-px flex w-0 flex-1 justify-end">
        {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" class="inline-flex items-center border-t-2 border-transparent pt-4 pl-1 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-white/20 dark:hover:text-gray-200">
          Next
          <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="ml-3 size-5 text-gray-400 dark:text-gray-500">
            <path d="M2 10a.75.75 0 0 1 .75-.75h12.59l-2.1-1.95a.75.75 0 1 1 1.02-1.1l3.5 3.25a.75.75 0 0 1 0 1.1l-3.5 3.25a.75.75 0 1 1-1.02-1.1l2.1-1.95H2.75A.75.75 0 0 1 2 10Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
        </a>
        {% else %}
        <span class="inline-flex items-center border-t-2 border-transparent pt-4 pl-1 text-sm font-medium text-gray-300 dark:text-gray-600">Next</span>
        {% endif %}
      </div>
    </nav>
    </div>
    <script>
      document.addEventListener('click', function(e) {
        if (e.target.tagName === 'A' && e.target.closest('#pagination-nav')) {
          e.preventDefault();
          const url = e.target.href;
          fetch(url)
            .then(response => {
              if (!response.ok) throw new Error('Page not found');
              return response.text();
            })
            .then(html => {
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const newGrid = doc.getElementById('post-grid');
              const newNav = doc.getElementById('pagination-nav');
              if (newGrid && newNav) {
                document.getElementById('post-grid').innerHTML = newGrid.innerHTML;
                document.getElementById('pagination-nav').innerHTML = newNav.innerHTML;
                history.pushState(null, '', url);
                // Scroll to the top of the post list smoothly
                document.getElementById('post-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            })
            .catch(err => console.error('Error loading page:', err));
        }
      });
    </script>
  </div>
</div>