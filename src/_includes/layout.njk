<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "Eleventy Tailwind Template" }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Manufacturing+Consent&family=Pirata+One&family=UnifrakturCook&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/assets/styles.generated.css' | url }}">
  </head>
  <body class="bg-cream-50 text-dark-black-900 font-sans">
    {% include "navbar.njk" %}
    {{ content | safe }}
    {% include "footer.njk" %}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
  </body>
</html>
